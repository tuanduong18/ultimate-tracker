# Backend environment — copy to backend/.env for local development.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ultimate_tracker
# JWKS endpoint of your Supabase project (Settings -> API -> JWT Keys):
# https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
CORS_ORIGINS=["http://localhost:3000"]
SENTRY_DSN=
