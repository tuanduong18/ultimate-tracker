# Copy to .env (root) for docker-compose, or use the per-app examples in
# frontend/.env.example and backend/.env.example for local dev.

# ---------- Backend (FastAPI) ----------
# Async SQLAlchemy URL. For docker-compose this points at the `db` service.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ultimate_tracker
# JWKS endpoint of your Supabase project (Settings -> API -> JWT Keys):
# https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
# Comma/JSON list of allowed CORS origins.
CORS_ORIGINS=["http://localhost:3000"]
# Optional error tracking.
SENTRY_DSN=

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
